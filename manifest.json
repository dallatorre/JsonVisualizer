{
    "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
    "manifestVersion": "1.17",
    "version": "1.0.0",
    "id": "649e1cb1-5bb1-4d32-b9dc-574bc8ba268c",
    "localizationInfo": {
        "defaultLanguageTag": "en-us",
        "additionalLanguages": []
    },
    "developer": {
        "name": "Contoso",
        "websiteUrl": "https://www.contoso.com",
        "privacyUrl": "https://www.contoso.com/privacy",
        "termsOfUseUrl": "https://www.contoso.com/servicesagreement"
    },
    "name": {
        "short": "JsonVisualizer",
        "full": "Contoso Task Pane Add-in"
    },
    "description": {
        "short": "A template to get started.",
        "full": "This is the template to get started."
    },
    "icons": {
        "outline": "assets/logo-filled.png",
        "color": "assets/logo-filled.png"
    },
    "accentColor": "#230201",
    "validDomains": [
        "contoso.com"
    ],
    "authorization": {
        "permissions": {
            "resourceSpecific": [
                {
                    "name": "MailboxItem.Read.User",
                    "type": "Delegated"
                }
            ]
        }
    },
    "extensions": [
        {
            "requirements": {
                "capabilities": [
                    {
                        "name": "Mailbox",
                        "minVersion": "1.3"
                    }
                ],
                "scopes": [
                    "mail"
                ]
            },
            "runtimes": [
                {
                    "requirements": {
                        "capabilities": [
                            {
                                "name": "Mailbox",
                                "minVersion": "1.3"
                            }
                        ]
                    },
                    "id": "TaskPaneRuntime",
                    "type": "general",
                    "code": {
                        "page": "https://localhost:3000/taskpane.html"
                    },
                    "lifetime": "short",
                    "actions": [
                        {
                            "id": "TaskPaneRuntimeShow",
                            "type": "openPage",
                            "pinnable": false,
                            "view": "dashboard"
                        }
                    ]
                },
                    {
                        "id": "TaskPaneRuntimeOpenAttachment",
                        "type": "general",
                        "code": {
                            "page": "https://localhost:3000/taskpane.html?openFirstAttachment=true"
                        },
                        "lifetime": "short",
                        "actions": [
                            {
                                "id": "TaskPaneRuntimeOpenAttachmentShow",
                                "type": "openPage",
                                "pinnable": false,
                                "view": "dashboard"
                            }
                        ]
                    },
                {
                    "id": "CommandsRuntime",
                    "type": "general",
                    "code": {
                        "page": "https://localhost:3000/commands.html",
                        "script": "https://localhost:3000/commands.js"
                    },
                    "lifetime": "short",
                    "actions": [
                        {
                            "id": "action",
                            "type": "executeFunction"
                        }
                    ]
                }
            ],
            "ribbons": [
                {
                    "contexts": [
                        "mailRead",
                        "mailCompose"
                    ],
                    "tabs": [
                        {
                            "builtInTabId": "TabDefault",
                            "groups": [
                                {
                                    "id": "msgReadGroup",
                                    "label": "Contoso Add-in",
                                    "icons": [
                                        {
                                            "size": 16,
                                            "url": "https://localhost:3000/assets/logo-filled.png"
                                        },
                                        {
                                            "size": 32,
                                            "url": "https://localhost:3000/assets/logo-filled.png"
                                        },
                                        {
                                            "size": 80,
                                            "url": "https://localhost:3000/assets/logo-filled.png"
                                        }
                                    ],
                                    "controls": [
                                        {
                                            "id": "msgReadOpenJsonAttachment",
                                            "type": "button",
                                            "label": "Apri JSON",
                                            "icons": [
                                                {
                                                    "size": 16,
                                                    "url": "https://localhost:3000/assets/logo-filled.png"
                                                },
                                                {
                                                    "size": 32,
                                                    "url": "https://localhost:3000/assets/logo-filled.png"
                                                }
                                            ],
                                            "supertip": {
                                                "title": "Apri allegato JSON",
                                                "description": "Apri automaticamente il primo allegato .json nel Task Pane"
                                            },
                                            "actionId": "TaskPaneRuntimeOpenAttachmentShow"
                                        }
                                    ]
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}